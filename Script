local function doHome()
	local sz = getSafeZone()
	if not sz then return end
	waitChar()
	safeTp(sz.CFrame + Vector3.new(0,3,0))
end

local function doCollect()
	for _,m in ipairs(lootFolder:GetChildren()) do
		if m:IsA("Model") then
			local ok,pv = pcall(function() return m:GetPivot() end)
			if ok then
				safeTp(pv + Vector3.new(0,1,0))
				task.wait(TELEPORT_DELAY)
			end
		end
	end
end

local function doSplit()
	local sz = getSplitZone()
	if not sz then return end
	waitChar()
	safeTp(sz.CFrame + Vector3.new(0,3,0))
	ReplicatedStorage:WaitForChild("Remotes"):WaitForChild("SplitRequest"):FireServer(1,true)
end

local function doSell()
	ReplicatedStorage:WaitForChild("Remotes"):WaitForChild("SellRequest"):FireServer({Mode="SellAll"})
end

collectBtn.MouseButton1Click:Connect(doCollect)
homeBtn.MouseButton1Click:Connect(doHome)
splitBtn.MouseButton1Click:Connect(doSplit)
sellBtn.MouseButton1Click:Connect(doSell)
